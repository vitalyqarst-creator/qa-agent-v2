{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "findings_markdown"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "accepted",
        "changes-required"
      ]
    },
    "findings_markdown": {
      "type": "string",
      "minLength": 1
    }
  }
}
