{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "status",
    "draft_markdown",
    "blocking_reasons"
  ],
  "properties": {
    "contract_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft-ready",
        "blocked-input"
      ]
    },
    "draft_markdown": {
      "type": "string",
      "maxLength": 131072
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
