work/
evals/runs/
evals/candidates/*
!evals/candidates/README.md

# Raw qualification runs stay local. Curated benchmark definitions and schema
# reservations are committed through their explicit allowlisted directories.
evals/sdk-turn-diagnostics/
evals/full-production-benchmark/*
!evals/full-production-benchmark/configs/
!evals/full-production-benchmark/configs/**
evals/lean-production-benchmark/
evals/schema-canary/*
!evals/schema-canary/qualification-registry/
!evals/schema-canary/qualification-registry/*.json

# FT packages and generated/manual test-case artifacts are intentionally out of
# the agent repository. Keep reusable agent rules in skills/ and references/.
fts/

# Generated archives
*.zip

# Binary/generated document artifacts
*.pdf
*.docx
*.xlsx
*.xls
*.png
*.jpg
*.jpeg

# Office temporary lock files
~$*

# Publish only the AutoFin FT package from fts/.
!fts/
fts/*
!fts/AutoFin/
!fts/AutoFin/**
# AutoFin source documents and UI mockups are local qualification inputs.
# Benchmarks bind them by hashes; never publish the original files.
fts/AutoFin/source/
fts/AutoFin/mockups/
fts/AutoFin/support/**/*.docx
fts/AutoFin/support/**/*.pdf
fts/AutoFin/support/**/*.xlsx
fts/AutoFin/support/**/*.xls
fts/AutoFin/support/**/*.png
fts/AutoFin/support/**/*.jpg
fts/AutoFin/support/**/*.jpeg
fts/AutoFin/test-cases/*shadow*.md
fts/AutoFin/work/
